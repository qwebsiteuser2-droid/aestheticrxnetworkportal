{
  "name": "q-website-backend",
  "version": "1.0.0",
  "description": "BioAestheticAx Network Backend API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "build:prod": "tsc -p tsconfig.prod.json; exit 0",
    "start": "node dist/server.js",
    "start:with-migrations": "npm run migration:run:prod && npm start",
    "dev": "ts-node --transpile-only src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/db/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/db/data-source.ts",
    "migration:run:prod": "NODE_ENV=production typeorm migration:run -d dist/db/data-source.js",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/db/data-source.ts",
    "seed": "ts-node --transpile-only src/db/seed.ts",
    "fix:missing-images": "ts-node --transpile-only src/scripts/fix-missing-upload-images.ts",
    "migrate:uploads-to-products-pics": "ts-node --transpile-only src/scripts/migrate-uploads-to-products-pics.ts"
  },
  "dependencies": {
    "archiver": "^6.0.2",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^6.11.2",
    "google-auth-library": "^10.5.0",
    "googleapis": "^128.0.0",
    "helmet": "^7.2.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.12",
    "pdfkit": "^0.13.0",
    "pg": "^8.16.3",
    "redis": "^4.7.1",
    "socket.io": "^4.7.5",
    "twilio": "^4.23.0",
    "typeorm": "^0.3.28",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.19.28",
    "@types/node-cron": "^3.0.8",
    "@types/nodemailer": "^7.0.3",
    "@types/pdfkit": "^0.12.10",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "api",
    "backend",
    "express",
    "typescript"
  ],
  "author": "BioAestheticAx Network Team",
  "license": "MIT"
}
