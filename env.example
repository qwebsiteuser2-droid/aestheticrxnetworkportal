# =============================================================================
# BioAestheticAx Network Environment Variables Configuration
# =============================================================================
# This file contains all environment variables needed for the BioAestheticAx Network platform
# Copy this file to .env and fill in your actual values
#
# Usage:
#   cp env.example .env
#   nano .env  # Edit with your values
#
# For production: cp env.example production.env
# =============================================================================

# =============================================================================
# ENVIRONMENT TYPE
# =============================================================================
# Set to: development, production, test
# Required: Yes
NODE_ENV=development

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# These variables are exposed to the browser (NEXT_PUBLIC_ prefix required)

# Backend API URL - Used by frontend to make API calls
# Development: http://localhost:4000
# Production: https://your-domain.com/api
# Required: Yes
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google Maps API Key - For location services and maps
# Get from: https://console.cloud.google.com/apis/credentials
# Required: Yes (if using location features)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =============================================================================
# BACKEND SERVER CONFIGURATION
# =============================================================================

# Server Port
# Default: 4000
# Required: No (defaults to 4000)
PORT=4000

# Frontend URL - Used for CORS and email links
# Development: http://localhost:3000
# Production: https://your-domain.com
# Required: Yes
FRONTEND_URL=http://localhost:3000

# Backend URL - Used for payment callbacks and API references
# Development: http://localhost:4000
# Production: https://your-domain.com/api
# Required: Yes
BACKEND_URL=http://localhost:4000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database Connection String
# Format: postgres://username:password@host:port/database
# 
# Local Development:
#   postgres://postgres:password@localhost:5432/bioaestheticax1
# Docker:
#   postgres://postgres:password@db:5432/bioaestheticax1
# Production (Google Cloud SQL):
#   postgres://user:pass@/dbname?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# Production (Standard):
#   postgres://user:pass@host:5432/dbname?sslmode=require
# Required: Yes
DATABASE_URL=postgres://postgres:password@localhost:5432/bioaestheticax1

# Redis Connection URL (Optional - for caching)
# Format: redis://host:port or redis://:password@host:port
# Required: No
# REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT Secret Key - Used to sign access tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum: 32 characters
# Required: Yes
JWT_SECRET=your_super_secure_jwt_secret_key_min_32_characters_here

# JWT Refresh Secret - Used to sign refresh tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum: 32 characters
# Required: Yes
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_key_min_32_characters_here

# JWT Access Token Expiration
# Format: 1h, 15m, 7d, etc.
# Default: 1h
# Required: No
JWT_EXPIRES_IN=1h

# JWT Refresh Token Expiration
# Format: 1h, 7d, 30d, etc.
# Default: 7d
# Required: No
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt Salt Rounds - Password hashing strength
# Higher = more secure but slower (12 is recommended)
# Range: 10-15
# Required: No (defaults to 12)
BCRYPT_SALT_ROUNDS=12

# OTP (One-Time Password) Configuration
# DISABLE_OTP - Set to 'true' or '1' to disable OTP requirement for login
# Useful when email service is not working (e.g., Railway SMTP issues)
# WARNING: Disabling OTP reduces security - only use temporarily
# Required: No (defaults to false - OTP enabled)
# DISABLE_OTP=false

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Gmail SMTP Configuration (Primary Email Service)
# Gmail User - Your Gmail email address
# Required: Yes (if using Gmail)
GMAIL_USER=your_email@gmail.com

# Gmail App Password - Generate from Google Account settings
# Steps: Google Account → Security → 2-Step Verification → App Passwords
# Required: Yes (if using Gmail)
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Email Batch Configuration (Spam Reduction)
# These settings control how emails are sent in batches to prevent spam filtering
# EMAIL_BATCH_SIZE - Number of emails per batch (recommended: 5-15, default: 10)
# EMAIL_DELAY_MS - Delay between individual emails in milliseconds (recommended: 1500-3000ms, default: 2000ms = 2 seconds)
# EMAIL_BATCH_DELAY_MS - Delay between batches in milliseconds (recommended: 5000-15000ms, default: 10000ms = 10 seconds)
# Required: No (uses defaults if not set)
EMAIL_BATCH_SIZE=10
EMAIL_DELAY_MS=2000
EMAIL_BATCH_DELAY_MS=10000

# Gmail Daily Limit Configuration
# GMAIL_DAILY_LIMIT - Maximum emails per day (default: 500 for free Gmail, 2000 for Google Workspace)
# The system automatically detects if using Google Workspace based on email domain
# Required: No (auto-detected, but can be overridden)
# GMAIL_DAILY_LIMIT=500

# SendGrid Configuration (Alternative Email Service)
# SendGrid API Key - Get from SendGrid dashboard
# Required: No (only if using SendGrid instead of Gmail)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@your-domain.com

# Use SendGrid for All Emails (Yes/No Configuration)
# Set to 'true', 'yes', or '1' to use SendGrid for ALL emails (even if they might go to spam)
# Set to 'false', 'no', or '0' to use Gmail SMTP first, SendGrid only as fallback
# Default: false (Gmail SMTP primary, SendGrid fallback)
# USE_SENDGRID_FOR_ALL_EMAILS=false

# =============================================================================
# ADMIN CONFIGURATION
# =============================================================================

# Main Admin Email - Primary administrator email
# Used for notifications and system alerts
# Required: Yes
MAIN_ADMIN_EMAIL=admin@your-domain.com

# Secondary Admin Email - Backup administrator email
# Used for notifications and system alerts
# Required: Yes
SECONDARY_ADMIN_EMAIL=admin2@your-domain.com

# Admin Email (Legacy - kept for compatibility)
# Required: No
# ADMIN_EMAIL=admin@your-domain.com

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION (PayFast)
# =============================================================================

# PayFast Merchant ID
# Get from: https://www.payfast.co.za/
# Required: Yes (if using PayFast)
PAYFAST_MERCHANT_ID=your_merchant_id_here

# PayFast Merchant Key
# Get from: PayFast merchant dashboard
# Required: Yes (if using PayFast)
PAYFAST_MERCHANT_KEY=your_merchant_key_here

# PayFast Passphrase
# Set in PayFast merchant settings
# Required: Yes (if using PayFast)
PAYFAST_PASSPHRASE=your_payfast_passphrase_here

# Note: PayFast automatically uses sandbox mode when NODE_ENV != production

# =============================================================================
# GOOGLE CLOUD SERVICES
# =============================================================================

# Google Drive Service Account Configuration
# Used for Google Drive integration and file storage
# Get from: Google Cloud Console → IAM & Admin → Service Accounts

# Google Private Key ID
# Required: No (only if using Google Drive features)
# GOOGLE_PRIVATE_KEY_ID=your_private_key_id_here

# Google Private Key
# Format: -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# Note: Replace \n with actual newlines or use environment variable
# Required: No (only if using Google Drive features)
# GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----

# Google Client ID
# Required: No (only if using Google Drive features)
# GOOGLE_CLIENT_ID=your_client_id_here

# Alternative: Use service-account.json file in /app directory
# If file exists, it will be used instead of environment variables

# =============================================================================
# CLOUD STORAGE CONFIGURATION (S3-Compatible)
# =============================================================================

# S3-Compatible Storage (Optional - for file storage)
# Supports: AWS S3, DigitalOcean Spaces, Google Cloud Storage, etc.

# S3 Endpoint URL
# AWS: https://s3.amazonaws.com
# DigitalOcean: https://region.digitaloceanspaces.com
# Required: No (only if using S3 storage)
# S3_ENDPOINT=https://your-region.digitaloceanspaces.com

# S3 Bucket Name
# Required: No (only if using S3 storage)
# S3_BUCKET=your-bucket-name

# S3 Access Key ID
# Required: No (only if using S3 storage)
# S3_KEY=your_access_key_id

# S3 Secret Access Key
# Required: No (only if using S3 storage)
# S3_SECRET=your_secret_access_key

# S3 Region
# Examples: us-east-1, eu-west-1, etc.
# Required: No (only if using S3 storage)
# S3_REGION=us-east-1

# =============================================================================
# SECURITY & RATE LIMITING
# =============================================================================

# CORS Origin - Allowed frontend origins
# Development: http://localhost:3000
# Production: https://your-domain.com
# Multiple origins: https://domain1.com,https://domain2.com
# Required: Yes
CORS_ORIGIN=http://localhost:3000

# Rate Limiting - Window in milliseconds
# Default: 900000 (15 minutes)
# Required: No
RATE_LIMIT_WINDOW_MS=900000

# Rate Limiting - Maximum requests per window
# Default: 100
# Required: No
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# Maximum File Size (in bytes)
# Default: 10485760 (10MB)
# Required: No
MAX_FILE_SIZE=10485760

# Allowed File Types (comma-separated MIME types)
# Required: No
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# =============================================================================
# AI SERVICES CONFIGURATION
# =============================================================================

# Hugging Face Token - For AI research features
# Get from: https://huggingface.co/settings/tokens
# Required: No (only if using AI research features)
# HF_TOKEN=your_hugging_face_token_here

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Audit Log Directory
# Default: ./logs (or ./tmp/logs in CI/test)
# Required: No
# AUDIT_LOG_DIR=./logs

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Allow Cloudflare Tunnels (for development)
# Set to: true or false
# Required: No
# ALLOW_CLOUDFLARE_TUNNELS=false

# Allow Test Endpoints (for development/testing)
# Set to: true or false
# Required: No
# ALLOW_TEST_ENDPOINTS=false

# CI Environment Flag
# Automatically set in CI/CD pipelines
# Required: No
# CI=false

# =============================================================================
# GOOGLE CLOUD DEPLOYMENT SPECIFIC
# =============================================================================
# Uncomment and configure these when deploying to Google Cloud Platform

# Google Cloud Project ID
# GCP_PROJECT_ID=your-project-id

# Google Cloud SQL Instance Connection Name
# Format: PROJECT_ID:REGION:INSTANCE_NAME
# GCP_SQL_INSTANCE=project-id:region:instance-name

# Google Cloud Storage Bucket (for file uploads)
# GCP_STORAGE_BUCKET=your-bucket-name

# Google Cloud Service Account JSON (base64 encoded)
# Alternative to individual Google credentials
# GCP_SERVICE_ACCOUNT_JSON=base64_encoded_json_here

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================
# 
# 1. Generate secure secrets:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. Use strong passwords for database
#
# 3. Enable SSL/TLS in production
#
# 4. Set NODE_ENV=production
#
# 5. Use environment-specific URLs
#
# 6. Never commit .env file to version control
#
# 7. Use secrets management (Google Secret Manager, AWS Secrets Manager, etc.)
#
# =============================================================================
